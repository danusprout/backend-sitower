generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Pegawai {
  id        String    @id @default(cuid())
  nik       String    @unique
  nama      String
  jabatan   String
  unit      String
  role      String    @default("teknisi")
  password  String
  aktif     Boolean   @default(true)
  foto      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  laporan                Laporan[]
  passwordChangeRequests PasswordChangeRequest[] @relation("RequesterRequests")
  reviewedRequests       PasswordChangeRequest[] @relation("ReviewerRequests")
}

model PasswordChangeRequest {
  id              String    @id @default(cuid())
  pegawaiId       String
  pegawai         Pegawai   @relation("RequesterRequests", fields: [pegawaiId], references: [id])
  newPasswordHash String
  status          String    @default("pending") // pending, approved, rejected
  requestedAt     DateTime  @default(now())
  expiredAt       DateTime
  reviewedAt      DateTime?
  reviewedById    String?
  reviewedBy      Pegawai?  @relation("ReviewerRequests", fields: [reviewedById], references: [id])
}

model TransmissionLineType {
  id        Int      @id @default(autoincrement())
  kode      String   @unique
  tegangan  String
  warna     String
  lineStyle String   @default("solid")
  createdAt DateTime @default(now())

  routes TransmissionRoute[]
}

model GarduInduk {
  id        Int      @id @default(autoincrement())
  kode      String   @unique
  nama      String
  lat       Float
  lng       Float
  tegangan  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  routesDari TransmissionRoute[] @relation("RouteDari")
  routesKe   TransmissionRoute[] @relation("RouteKe")
}

model TransmissionRoute {
  id          Int                  @id @default(autoincrement())
  nama        String
  lineTypeId  Int
  lineType    TransmissionLineType @relation(fields: [lineTypeId], references: [id])
  garduDariId Int
  garduDari   GarduInduk           @relation("RouteDari", fields: [garduDariId], references: [id])
  garduKeId   Int
  garduKe     GarduInduk           @relation("RouteKe", fields: [garduKeId], references: [id])
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  towers Tower[]
}

model Tower {
  id        String   @id
  nama      String
  lat       Float
  lng       Float
  tegangan  String
  tipe      String
  kondisi   String   @default("normal")
  lokasi    String?
  radius    Float    @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jalur     String?
  nomorUrut Int?

  routeId         Int?
  route           TransmissionRoute? @relation(fields: [routeId], references: [id])
  statusKerawanan String             @default("aman")
  jenisKerawanan  String?
  pplNotes        String?
  penanggungJawab String?
  telepon         String?
  sertifikatLink  String?

  laporan        Laporan[]
  sertifikat     Sertifikat[]
  asBuilt        AsBuiltDrawing[]
  asBuiltFolders AsBuiltFolder[]
}

model Laporan {
  id        String  @id @default(cuid())
  towerId   String
  tower     Tower   @relation(fields: [towerId], references: [id])
  pelaporId String
  pelapor   Pegawai @relation(fields: [pelaporId], references: [id])

  jenisGangguan String
  deskripsi     String
  levelRisiko   String
  status        String   @default("berlangsung")
  tanggal       DateTime
  lokasiDetail  String?
  keterangan String?
  foto      String[]

  noSpk    String?
  teknisi  String?
  temuan   String?
  hasil    String?
  penyebab String?
  durasi   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress    ProgressLaporan[]
  fotoHistory FotoHistory[]
}

model ProgressLaporan {
  id        String   @id @default(cuid())
  laporanId String
  laporan   Laporan  @relation(fields: [laporanId], references: [id], onDelete: Cascade)
  tipe      String   // spanduk | brosur | laporan_baru | berita_acara
  fileUrl   String
  namaFile  String
  createdAt DateTime @default(now())
}

model FotoHistory {
  id        String   @id @default(cuid())
  laporanId String
  laporan   Laporan  @relation(fields: [laporanId], references: [id], onDelete: Cascade)
  urls      String[]
  createdAt DateTime @default(now())
}

model Sertifikat {
  id            String              @id @default(cuid())
  nama          String
  kategori      String
  status        String              @default("berlaku")
  towerId       String?
  tower         Tower?              @relation(fields: [towerId], references: [id])
  berlakuHingga DateTime?
  dokumen       SertifikatDokumen[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model SertifikatDokumen {
  id        String     @id @default(cuid())
  folderId  String
  folder    Sertifikat @relation(fields: [folderId], references: [id], onDelete: Cascade)
  namaFile  String
  fileUrl   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model AsBuiltDrawing {
  id         String   @id @default(cuid())
  towerId    String
  tower      Tower    @relation(fields: [towerId], references: [id])
  namaFile   String
  tipe       String
  tahun      Int
  versi      String?
  fileUrl    String?
  keterangan String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AsBuiltFolder {
  id         String          @id @default(cuid())
  nama       String
  tipe       String
  tahun      Int
  towerId    String?
  tower      Tower?          @relation(fields: [towerId], references: [id])
  keterangan String?
  dokumen    AsBuiltDokumen[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model AsBuiltDokumen {
  id        String        @id @default(cuid())
  folderId  String
  folder    AsBuiltFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  namaFile  String
  fileUrl   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model JalurKML {
  id        Int      @id @default(autoincrement())
  nama      String
  tipe      String   @default("SUTT")
  warna     String?
  path      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
